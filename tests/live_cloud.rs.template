//! Live cloud TTS tests that need real credentials.
//!
//! THIS FILE IS GITIGNORED — copy this template to tests/live_cloud.rs and
//! adapt. The .env.example file lists every env var referenced here.
//!
//! All tests are #[ignore]-d so they never run by accident in CI. Run with:
//!
//!     cargo test --test live_cloud --features cloud -- --ignored --nocapture
//!
//! Or via the helper script (also gitignored):
//!
//!     ./run-live-tests.sh
//!
//! What these tests verify that the offline suite can't:
//!   - Google v1beta1 real timepoints (boundary offset == audio frame offset)
//!   - Azure WebSocket word-boundary turn protocol
//!   - ElevenLabs /with-timestamps character alignment
//!   - Streaming chunk size & count across providers
//!   - SpeechMarkdown end-to-end per platform (Azure Microsoft SSML,
//!     Google Assistant SSML, others Alexa SSML)
//!   - check_credentials() returns true with valid keys

#![allow(clippy::all, clippy::pedantic, clippy::float_cmp)]

use rust_tts_wrapper::engine::TtsEngine;
use rust_tts_wrapper::factory::create_engine;
use std::sync::{Arc, Mutex};

/// Build an engine or skip the test cleanly when the env var isn't set.
macro_rules! require_engine {
    ($id:expr, $creds_json:expr, $env_var:expr) => {{
        if std::env::var($env_var).is_err() {
            eprintln!("skipping: set {} to run this test", $env_var);
            return;
        }
        create_engine($id, $creds_json).expect("engine")
    }};
}

struct AudioSink {
    chunks: Vec<usize>,
    total: usize,
}
impl AudioSink {
    fn new() -> Self {
        Self {
            chunks: Vec::new(),
            total: 0,
        }
    }
}

struct BoundarySink {
    words: Vec<(String, f32, f32)>,
}
impl BoundarySink {
    fn new() -> Self {
        Self { words: Vec::new() }
    }
}

// ===== Google — real timepoints =====

#[test]
#[ignore]
fn google_real_timepoints_match_words() {
    let key = std::env::var("GOOGLE_TTS_API_KEY").unwrap_or_default();
    if key.is_empty() {
        eprintln!("skipping: GOOGLE_TTS_API_KEY not set");
        return;
    }
    let creds = format!(r#"{{"apiKey":"{key}"}}"#);
    let engine = create_engine("google", &creds).expect("google engine");
    let sink = Arc::new(Mutex::new(BoundarySink::new()));
    let s = sink.clone();
    let mut cb = move |w: &str, st: f32, e: f32, _: i32, _: i32| {
        s.lock().unwrap().words.push((w.into(), st, e));
    };
    let text = "Hello world testing";
    engine
        .speak(text, Some("en-US-Wavenet-D"), 1.0, 1.0, 1.0, None, Some(&mut cb))
        .expect("google speak");

    let words = sink.lock().unwrap().words.clone();
    let expected: Vec<&str> = text.split_whitespace().collect();
    assert_eq!(words.len(), expected.len(), "one real timepoint per word");
    // Real (not estimated) timing: offsets must be non-zero after the first
    // word and strictly increasing.
    for w in words.windows(2) {
        assert!(w[1].1 > w[0].1, "real timepoints must be strictly increasing");
    }
}

