# Copy to .env (or tests/live_cloud.env) and fill in after rotating keys.
# NEVER commit real credentials. .env and *.live.env are gitignored.
#
# These are read by tests/live_cloud.rs (run with: cargo test --test live_cloud -- --ignored).

# Google Cloud TTS (one of the two keys)
GOOGLE_TTS_API_KEY=your-google-key

# Microsoft Azure TTS
AZURE_SUBSCRIPTION_KEY=your-azure-key
AZURE_REGION=uksouth

# IBM Watson
WATSON_API_KEY=your-watson-key
WATSON_REGION=eu-gb
WATSON_INSTANCE_ID=your-instance-id

# AWS Polly (currently disabled in code — SigV4 not implemented)
POLLY_REGION=us-east-1
POLLY_AWS_KEY_ID=your-aws-key-id
POLLY_AWS_ACCESS_KEY=your-aws-secret

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key

# Wit.ai
WITAI_TOKEN=your-witai-token

# PlayHT
PLAYHT_API_KEY=your-playht-key
PLAYHT_USER_ID=your-playht-user-id

# OpenAI
OPENAI_API_KEY=your-openai-key

# Cartesia
CARTESIA_API_KEY=your-cartesia-key

# Deepgram
DEEPGRAM_API_KEY=your-deepgram-key

# Fish Audio
FISHAUDIO_API_KEY=your-fishaudio-key

# Hume AI
HUME_API_KEY=your-hume-key

# Mistral
MISTRAL_API_KEY=your-mistral-key

# Murf
MURF_API_KEY=your-murf-key

# Resemble AI
RESEMBLE_API_KEY=your-resemble-key

# Unreal Speech
UNREALSPEECH_API_KEY=your-unrealspeech-key

# UpliftAI
UPLIFTAI_API_KEY=your-upliftai-key

# xAI
XAI_API_KEY=your-xai-key

# ModelsLab
MODELSLAB_API_KEY=your-modelslab-key
