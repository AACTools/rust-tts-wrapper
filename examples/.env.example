# Environment Variables for Rust TTS Wrapper Examples
# Copy this file to .env and fill in your API keys

# OpenAI (for GPT-4o-mini TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Azure Speech Services
AZURE_SUBSCRIPTION_KEY=your_azure_subscription_key_here
AZURE_REGION=eastus

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Google Cloud Text-to-Speech
GOOGLE_API_KEY=your_google_api_key_here

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Play.ht
PLAYHT_API_KEY=your_playht_api_key_here
PLAYHT_USER_ID=your_playht_user_id_here

# Cartesia
CARTESIA_API_KEY=your_cartesia_api_key_here

# Hume AI
HUME_API_KEY=your_hume_api_key_here

# Watson
WATSON_API_KEY=your_watson_api_key_here
WATTON_URL=your_watson_url_here

# Amazon Polly (requires AWS credentials setup)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Notes:
# - Only set the API keys for services you have access to
# - Examples will skip providers that don't have credentials set
# - System TTS (eSpeak/Speech Dispatcher) works without any API keys
# - Windows SAPI works without credentials on Windows systems