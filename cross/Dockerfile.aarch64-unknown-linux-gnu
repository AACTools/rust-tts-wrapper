FROM ghcr.io/cross-rs/aarch64-unknown-linux-gnu:0.2.5

RUN dpkg --add-architecture arm64 && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    libspeechd-dev:arm64 \
    && echo "=== Looking for speech-dispatcher headers ===" \
    && find / -name "libspeechd.h" 2>/dev/null || true \
    && echo "=== /usr/include ===" \
    && ls /usr/include/speech-dispatcher 2>/dev/null || echo "no /usr/include/speech-dispatcher" \
    && echo "=== /usr/include/aarch64-linux-gnu ===" \
    && ls /usr/include/aarch64-linux-gnu/speech-dispatcher 2>/dev/null || echo "no aarch64 path" \
    && ln -sf /usr/include/aarch64-linux-gnu/speech-dispatcher /usr/include/speech-dispatcher || \
       (find / -path "*/speech-dispatcher" -type d 2>/dev/null | head -3 && echo "ERROR: no speech-dispatcher dir found") \
    && rm -rf /var/lib/apt/lists/*
