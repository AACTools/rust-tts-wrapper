// ===== Generic per-provider smoke test =====
//
// Drives every provider that has its key in env through the same shape:
// construct, synth_to_bytes, assert non-empty. Catches regressions in
// auth/URL/body shapes that single-provider tests might miss.

#[test]
#[ignore]
fn per_provider_smoke_matrix() {
    let cases: Vec<(&str, &str, &str)> = vec![
        ("openai", "OPENAI_API_KEY", r#"{"apiKey":"$K"}"#),
        ("elevenlabs", "ELEVENLABS_API_KEY", r#"{"apiKey":"$K"}"#),
        ("cartesia", "CARTESIA_API_KEY", r#"{"apiKey":"$K"}"#),
        ("deepgram", "DEEPGRAM_API_KEY", r#"{"apiKey":"$K"}"#),
        ("fishaudio", "FISHAUDIO_API_KEY", r#"{"apiKey":"$K"}"#),
        ("hume", "HUME_API_KEY", r#"{"apiKey":"$K"}"#),
        ("mistral", "MISTRAL_API_KEY", r#"{"apiKey":"$K"}"#),
        ("murf", "MURF_API_KEY", r#"{"apiKey":"$K"}"#),
        ("resemble", "RESEMBLE_API_KEY", r#"{"apiKey":"$K"}"#),
        ("unrealspeech", "UNREALSPEECH_API_KEY", r#"{"apiKey":"$K"}"#),
        ("upliftai", "UPLIFTAI_API_KEY", r#"{"apiKey":"$K"}"#),
        ("xai", "XAI_API_KEY", r#"{"apiKey":"$K"}"#),
        ("witai", "WITAI_TOKEN", r#"{"token":"$K"}"#),
    ];

    for (id, env_var, template) in cases {
        let key = match std::env::var(env_var) {
            Ok(k) if !k.is_empty() => k,
            _ => {
                eprintln!("skipping {id}: {env_var} not set");
                continue;
            }
        };
        let creds = template.replace("$K", &key);
        let engine = match create_engine(id, &creds) {
            Some(e) => e,
            None => {
                panic!("create_engine({id}) returned None");
            }
        };
        match engine.synth_to_bytes("Hello world.", None, 1.0, 1.0, 1.0) {
            Ok(audio) => assert!(!audio.is_empty(), "{id} produced empty audio"),
            Err(e) => panic!("{id} synth error: {e}"),
        }
        eprintln!("{id}: OK");
    }
}
