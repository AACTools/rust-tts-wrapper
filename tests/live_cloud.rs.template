#[test]
#[ignore]
fn google_streaming_chunks_are_at_most_8kb() {
    let key = std::env::var("GOOGLE_TTS_API_KEY").unwrap_or_default();
    if key.is_empty() {
        eprintln!("skipping");
        return;
    }
    let creds = format!(r#"{{"apiKey":"{key}"}}"#);
    let engine = create_engine("google", &creds).expect("google");
    let sink = Arc::new(Mutex::new(AudioSink::new()));
    let s = sink.clone();
    let mut cb = move |c: &[u8]| {
        let mut sink = s.lock().unwrap();
        sink.chunks.push(c.len());
        sink.total += c.len();
    };
    engine
        .speak(
            "This is a longer sentence to produce multiple streaming chunks.",
            Some("en-US-Wavenet-D"),
            1.0,
            1.0,
            1.0,
            Some(&mut cb),
            None,
        )
        .expect("speak");
    let sink = sink.lock().unwrap();
    assert!(sink.total > 0);
    assert!(sink.chunks.iter().all(|&n| n <= 8192), "chunk > 8KB leaked");
}

// ===== Azure — real WebSocket word boundaries =====

#[test]
#[ignore]
fn azure_ws_real_word_boundaries_fire() {
    let key = std::env::var("AZURE_SUBSCRIPTION_KEY").unwrap_or_default();
    let region = std::env::var("AZURE_REGION").unwrap_or_else(|_| "eastus".into());
    if key.is_empty() {
        eprintln!("skipping: AZURE_SUBSCRIPTION_KEY not set");
        return;
    }
    let creds = format!(r#"{{"subscriptionKey":"{key}","region":"{region}"}}"#);
    let engine = create_engine("azure", &creds).expect("azure");
    let sink = Arc::new(Mutex::new(BoundarySink::new()));
    let s = sink.clone();
    let mut cb = move |w: &str, st: f32, e: f32, _: i32, _: i32| {
        s.lock().unwrap().words.push((w.into(), st, e));
    };
    let text = "Azure WebSocket real word boundary test.";
    engine
        .speak(text, Some("en-US-AriaNeural"), 1.0, 1.0, 1.0, None, Some(&mut cb))
        .expect("azure speak");

    let words = sink.lock().unwrap().words.clone();
    assert!(!words.is_empty(), "Azure WS should emit real boundaries");
    // Real boundaries fire roughly at audio-frame time — they're non-zero
    // for words after the first and strictly increasing.
    assert!(words.windows(2).all(|w| w[0].1 < w[1].1));
}

